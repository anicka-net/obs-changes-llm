# GBNF grammar for openSUSE .changes entry body
# Enforces: "- " prefix for L1, "  * " for L2, proper wrapping indent
# The header (dashes + timestamp) is NOT generated by the model
# Line length is guided by prompt (grammar can't do {1,67} ranges cleanly)

root         ::= entry+

entry        ::= l1-line wrap-line* l2-entry*
l2-entry     ::= l2-line wrap2-line*

l1-line      ::= "- " line-text "\n"
wrap-line    ::= "  " line-text "\n"
l2-line      ::= "  * " line-text "\n"
wrap2-line   ::= "    " line-text "\n"

line-text    ::= char+
char         ::= [^\n]
